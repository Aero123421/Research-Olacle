{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Aero123421/Research-Olacle/blob/main/.research-lab/schema/campaign-handoff.schema.json",
  "title": "Campaign Handoff",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "campaign_id",
    "outcome",
    "summary",
    "evidence",
    "confirmed_findings",
    "rejected_hypotheses",
    "unexpected_observations",
    "strategic_implications",
    "executor_recommendations",
    "resources_actual",
    "limitations"
  ],
  "properties": {
    "campaign_id": {"type": "string", "pattern": "^C-[0-9]{3,}$"},
    "outcome": {
      "enum": ["success", "promising", "rejected_with_evidence", "surprise", "strategy_conflict", "blocked", "budget_exhausted", "invalid"]
    },
    "summary": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["claim", "artifact", "commit"],
        "properties": {
          "claim": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "commit": {"type": "string", "minLength": 1},
          "experiment_id": {"type": "string"}
        }
      }
    },
    "confirmed_findings": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "rejected_hypotheses": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "unexpected_observations": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "strategic_implications": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "executor_recommendations": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "resources_actual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_hours", "gpu_hours", "cost_jpy"],
      "properties": {
        "wall_hours": {"type": "number", "minimum": 0},
        "gpu_hours": {"type": "number", "minimum": 0},
        "cost_jpy": {"type": "number", "minimum": 0}
      }
    },
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
