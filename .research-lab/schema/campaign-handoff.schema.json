{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Aero123421/Research-Olacle/blob/main/.research-lab/schema/campaign-handoff.schema.json",
  "title": "Campaign Handoff",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "campaign_id",
    "outcome",
    "summary",
    "evidence",
    "confirmed_findings",
    "rejected_hypotheses",
    "unexpected_observations",
    "strategic_implications",
    "executor_recommendations",
    "resources_actual",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        1,
        2
      ]
    },
    "campaign_id": {
      "type": "string",
      "pattern": "^C-[0-9]{3,}$"
    },
    "outcome": {
      "enum": [
        "success",
        "promising",
        "rejected_with_evidence",
        "surprise",
        "strategy_conflict",
        "blocked",
        "budget_exhausted",
        "invalid"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "claim",
          "artifact",
          "commit"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "artifact": {
            "type": "string",
            "minLength": 1
          },
          "commit": {
            "type": "string",
            "minLength": 1
          },
          "experiment_id": {
            "type": "string"
          },
          "observation": {
            "type": "string",
            "minLength": 1
          },
          "inference": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "confirmed_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rejected_hypotheses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unexpected_observations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategic_implications": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "executor_recommendations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resources_actual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_hours",
        "gpu_hours",
        "cost_jpy"
      ],
      "properties": {
        "wall_hours": {
          "type": "number",
          "minimum": 0
        },
        "gpu_hours": {
          "type": "number",
          "minimum": 0
        },
        "cost_jpy": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unverified_leads": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_reversal_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "schema_version"
        ],
        "properties": {
          "schema_version": {
            "const": 2
          }
        }
      },
      "then": {
        "required": [
          "assumptions",
          "unresolved_questions",
          "unverified_leads",
          "decision_reversal_evidence"
        ],
        "properties": {
          "evidence": {
            "items": {
              "required": [
                "observation",
                "inference",
                "confidence"
              ]
            }
          }
        }
      }
    }
  ]
}
